# === Server ===
NODE_ENV=production
PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/azlik

# JWT
JWT_SECRET=replace_with_long_random_string
SESSION_SECRET=replace_with_long_random_string_for_sessions

# Cloudinary (required for image uploads on Vercel)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-app.vercel.app/api/auth/google/callback

# Frontend redirect (used after Google OAuth)
FRONTEND_URL=https://your-app.vercel.app

# Comma-separated list of allowed origins (leave empty to allow all)
CORS_ORIGINS=https://your-app.vercel.app

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM_NAME="AZLIK"
EMAIL_FROM_ADDRESS=no-reply@azlik.com

# Admin
ADMIN_EMAIL=admin@azlik.com

# === Client (set in Vercel FE env) ===
# Leave unset to use same-origin "/api" (recommended for single-project deploy)
# VITE_API_URL=/api
